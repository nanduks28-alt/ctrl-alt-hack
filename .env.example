# SRE-Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Supabase (required) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic Claude (optional — enables real AI analysis) ───
# Get a key at https://console.anthropic.com
# Without this, Bob falls back to intelligent simulation mode.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── GitHub (optional — enables redeployment recovery) ────────
# Create a PAT at https://github.com/settings/tokens
# Needs: repo, workflow scopes
GITHUB_TOKEN=ghp_your-token-here

# ── Monitor settings (optional) ──────────────────────────────
MONITOR_INTERVAL_SECONDS=30
MONITOR_TIMEOUT_SECONDS=10
